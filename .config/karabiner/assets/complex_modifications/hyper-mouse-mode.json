                                "value": 1
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "hyper_mouse_mode_status",
                                "text": "MOUSE MODE — h/j/k/l move, ⇧+h/j/k/l slow, ⌘+h/j/k/l scroll, Space click, ⌘+Space right-click, Esc exit"
                            }
                        }
                    ],
                    "type": "basic"
                },
