{
    "title": "Caps Lock Hyper and nav layer",
    "rules": [
        {
            "description": "Double press Caps Lock toggles nav layer; HJKL arrows; 9 minus; 0 plus",
            "manipulators": [
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer_double_press_pending",
                            "type": "variable_if",
                            "value": 1
                        },
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "caps_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "caps_nav_layer_double_press_pending",
                                "value": 0
                            }
                        },
                        {
                            "set_variable": {
                                "name": "caps_nav_layer",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "caps_nav_layer_status",
                                "text": ""
                            }
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer_double_press_pending",
                            "type": "variable_if",
                            "value": 1
                        },
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_unless",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "caps_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "caps_nav_layer_double_press_pending",
                                "value": 0
                            }
                        },
                        {
                            "set_variable": {
                                "name": "caps_nav_layer",
                                "value": 1
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "caps_nav_layer_status",
                                "text": "CAPS NAV - h/j/k/l arrows, 9 -, 0 +"
                            }
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "h",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "left_arrow"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "j",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "down_arrow"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "k",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "up_arrow"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "l",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "right_arrow"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "9",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "hyphen"
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "caps_nav_layer",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "0",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "equal_sign",
                            "modifiers": [
                                "shift"
                            ]
                        }
                    ],
                    "type": "basic"
                }
            ]
        },
        {
            "description": "Caps Lock to Hyper; alone does nothing",
            "manipulators": [
                {
                    "from": {
                        "key_code": "caps_lock",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "parameters": {
                        "basic.to_delayed_action_delay_milliseconds": 100
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "caps_nav_layer_double_press_pending",
                                "value": 1
                            }
                        },
                        {
                            "key_code": "left_shift",
                            "lazy": true,
                            "modifiers": [
                                "left_command",
                                "left_control",
                                "left_option"
                            ]
                        }
                    ],
                    "to_delayed_action": {
                        "to_if_canceled": [
                            {
                                "set_variable": {
                                    "name": "caps_nav_layer_double_press_pending",
                                    "value": 0
                                }
                            }
                        ],
                        "to_if_invoked": [
                            {
                                "set_variable": {
                                    "name": "caps_nav_layer_double_press_pending",
                                    "value": 0
                                }
                            }
                        ]
                    },
                    "to_if_alone": [
                        {
                            "key_code": "vk_none"
                        }
                    ],
                    "type": "basic"
                }
            ]
        }
    ]
}
