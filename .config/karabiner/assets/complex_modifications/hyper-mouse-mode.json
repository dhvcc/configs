{
    "title": "Hyper mouse mode",
    "rules": [
        {
            "description": "Hyper+M toggles mouse mode with indicator; HJKL moves mouse; Shift+HJKL moves slowly; Cmd+HJKL scrolls; Space clicks/drags; Cmd+Space right-clicks; Esc exits",
            "manipulators": [
                {
                    "conditions": [
                        {
                            "name": "hyper_mouse_mode",
                            "type": "variable_if",
                            "value": 1
                        }
                    ],
                    "from": {
                        "key_code": "m",
                        "modifiers": {
                            "mandatory": [
                                "control",
                                "option",
                                "command",
                                "shift"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "hyper_mouse_mode",
                                "value": 0
                            }
                        },
                        {
                            "set_notification_message": {
                                "id": "hyper_mouse_mode_status",
                                "text": ""
                            }
                        }
                    ],
                    "type": "basic"
                },
                {
                    "conditions": [
                        {
                            "name": "hyper_mouse_mode",
                            "type": "variable_unless",
                            "value": 1
                        }
